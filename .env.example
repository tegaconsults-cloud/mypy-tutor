# Required
GROQ_API_KEY=your-groq-api-key-here
SESSION_SECRET=change-this-to-a-random-32-char-string

# Google OAuth (optional — Sign In with Google)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Email (Gmail SMTP) — for email sign-up + confirmation
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password   # Google Account > Security > App Passwords
EMAIL_FROM=MyPy Tutor <your-gmail@gmail.com>
APP_URL=https://mypy-tutor.onrender.com
